{
  "name": "@nano_kit/svelte-router",
  "type": "module",
  "version": "1.0.0-alpha.5",
  "description": "Svelte integration for @nano_kit/router with code splitting, Dependency Injection, and state management.",
  "author": "dangreen",
  "license": "MIT",
  "homepage": "https://nano-kit.js.org/integrations/svelte-router",
  "funding": "https://ko-fi.com/dangreen",
  "repository": {
    "type": "git",
    "url": "https://github.com/TrigenSoftware/nano_kit.git",
    "directory": "packages/svelte-router"
  },
  "bugs": {
    "url": "https://github.com/TrigenSoftware/nano_kit/issues"
  },
  "keywords": [
    "svelte",
    "router",
    "routing",
    "navigation",
    "store",
    "state",
    "signal",
    "reactive",
    "nano_kit"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "svelte": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "directory": "package",
    "linkDirectory": false
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clear:package": "del ./package",
    "clear:dist": "del ./dist",
    "clear:dist-assets": "del './dist/**.{spec,stories}.*'",
    "clear": "del ./package ./dist ./.svelte-kit ./coverage",
    "prepublishOnly": "run build clear:package clean-publish",
    "postpublish": "pnpm clear:package",
    "build:dist": "svelte-package --input src --output dist --tsconfig tsconfig.build.json",
    "build": "run clear:dist build:dist clear:dist-assets",
    "lint": "oxlint",
    "format": "oxlint --fix",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest watch",
    "test:ts": "tsgo --noEmit",
    "test:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "test:dist-types": "run build:dist [ node ../../scripts/check-dist-app-routes.js dist/link.d.ts ]",
    "test:types": "run -p test:ts test:svelte test:dist-types",
    "test": "run -p lint test:unit test:types"
  },
  "peerDependencies": {
    "@nano_kit/router": "workspace:^",
    "@nano_kit/store": "workspace:^",
    "@nano_kit/svelte": "workspace:^",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@nano_kit/router": "workspace:^",
    "@nano_kit/store": "workspace:^",
    "@nano_kit/svelte": "workspace:^",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/svelte": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}

{
  "name": "@nanoviews/storybook-vite",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "description": "Nanoviews + Vite framework for storybook.",
  "author": "dangreen",
  "license": "MIT",
  "funding": "https://ko-fi.com/dangreen",
  "repository": {
    "type": "git",
    "url": "https://github.com/TrigenSoftware/nano_kit.git",
    "directory": "packages/storybook-vite"
  },
  "bugs": {
    "url": "https://github.com/TrigenSoftware/nano_kit/issues"
  },
  "keywords": [
    "storybook",
    "vite",
    "framework",
    "ui",
    "nanoviews",
    "nano_kit"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./node": "./src/node.js",
    "./preset": "./src/preset.js"
  },
  "publishConfig": {
    "directory": "package",
    "linkDirectory": false
  },
  "files": [
    "src"
  ],
  "scripts": {
    "clear:package": "del ./package",
    "clear": "del ./package ./coverage",
    "prepublishOnly": "run clear:package clean-publish",
    "postpublish": "pnpm clear:package",
    "lint": "eslint --flag v10_config_lookup_from_file",
    "test": "run lint"
  },
  "peerDependencies": {
    "@nanoviews/storybook": "workspace:^",
    "storybook": "^10.3.5",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@storybook/builder-vite": "^10.3.5"
  },
  "devDependencies": {
    "@nanoviews/storybook": "workspace:^",
    "storybook": "catalog:",
    "vite": "catalog:"
  }
}

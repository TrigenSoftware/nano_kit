{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "rootDir": "./src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.config.ts",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/client.jsx",
    "src/renderer.jsx"
  ]
}

{
  "name": "@nano_kit/svelte-ssr",
  "type": "module",
  "version": "1.0.0-alpha.4",
  "description": "The Svelte adapter for server-side rendering in Nano Kit.",
  "author": "dangreen",
  "license": "MIT",
  "homepage": "https://nano-kit.js.org/integrations/svelte-ssr",
  "funding": "https://ko-fi.com/dangreen",
  "repository": {
    "type": "git",
    "url": "https://github.com/TrigenSoftware/nano_kit.git",
    "directory": "packages/svelte-ssr"
  },
  "bugs": {
    "url": "https://github.com/TrigenSoftware/nano_kit/issues"
  },
  "keywords": [
    "router",
    "routing",
    "navigation",
    "vite",
    "vite-plugin",
    "ssr",
    "nano_kit",
    "svelte"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "exports": {
    "./vite-plugin": "./src/vite-plugin/index.js",
    "./renderer": "./src/renderer/index.ts",
    "./client": "./src/client/index.ts"
  },
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      "./vite-plugin": {
        "types": "./dist/vite-plugin/index.d.ts",
        "import": "./dist/vite-plugin/index.js"
      },
      "./renderer": {
        "types": "./dist/renderer/index.d.ts",
        "import": "./dist/renderer/index.js"
      },
      "./client": {
        "types": "./dist/client/index.d.ts",
        "import": "./dist/client/index.js"
      }
    },
    "directory": "package",
    "linkDirectory": false
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clear:package": "del ./package",
    "clear:dist": "del ./dist",
    "clear": "del ./package ./dist ./coverage",
    "prepublishOnly": "run build clear:package clean-publish",
    "postpublish": "pnpm clear:package",
    "build:dist": "tsc -p tsconfig.build.json; cpy ./src/vite-plugin/index.d.ts ./dist/vite-plugin --flat; cpy './src/{client,renderer}.js' ./dist --flat",
    "build": "run clear:dist build:dist",
    "lint": "oxlint",
    "format": "oxlint --fix",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest watch",
    "test:ts": "tsc --noEmit",
    "test:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "test:types": "run -p test:ts test:svelte",
    "test": "run -p lint test:unit test:types"
  },
  "peerDependencies": {
    "@nano_kit/svelte": "workspace:^",
    "@nano_kit/svelte-router": "workspace:^",
    "@nano_kit/router": "workspace:^",
    "@nano_kit/store": "workspace:^",
    "svelte": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "@nano_kit/ssr": "workspace:^"
  },
  "devDependencies": {
    "@nano_kit/router": "workspace:^",
    "@nano_kit/store": "workspace:^",
    "@nano_kit/svelte": "workspace:^",
    "@nano_kit/svelte-router": "workspace:^",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cpy-cli": "^7.0.0",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "^6.0.0",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}

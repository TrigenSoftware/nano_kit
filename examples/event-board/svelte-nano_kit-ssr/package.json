{
  "name": "event-board-svelte-nano_kit-ssr",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "build:only": "vite build",
    "preview": "node dist/server/index.js",
    "start": "node dist/server/index.js",
    "test:types": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@nano_kit/query": "*",
    "@nano_kit/router": "*",
    "@nano_kit/store": "*",
    "@nano_kit/svelte": "*",
    "@nano_kit/svelte-router": "*",
    "@nano_kit/svelte-ssr": "*",
    "hono": "^4.12.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "typescript": "^6.0.0",
    "vite": "^8.0.8"
  }
}

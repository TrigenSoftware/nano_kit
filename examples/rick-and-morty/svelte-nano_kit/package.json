{
  "name": "rick-and-morty-svelte-nano_kit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@nano_kit/query": "*",
    "@nano_kit/router": "*",
    "@nano_kit/store": "*",
    "@nano_kit/svelte": "*",
    "@nano_kit/svelte-router": "*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "typescript": "^6.0.0",
    "vite": "^8.0.8"
  }
}
